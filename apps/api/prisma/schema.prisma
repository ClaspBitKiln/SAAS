// СОБРАННАЯ схема (ADR-014). Источник истины — packages/<ctx>/prisma/*.
// Здесь добавлены generator/datasource + модели контекстов по мере готовности.
// Сейчас: Platform → Tenant. Не редактировать вручную после внедрения merge-скрипта.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== context: platform (packages/platform/prisma/schema.prisma) =====
enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum PlanType {
  FREE
  PRO
  BUSINESS
}

model Tenant {
  id        String       @id @db.Uuid
  name      String       @db.VarChar(255)
  slug      String       @unique @db.VarChar(64)
  plan      PlanType     @default(FREE)
  status    TenantStatus @default(ACTIVE)
  version   Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@map("tenants")
}
