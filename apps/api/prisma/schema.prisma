// СОБРАННАЯ схема (ADR-014). Источник истины — packages/<ctx>/prisma/*.
// Здесь добавлены generator/datasource + модели контекстов по мере готовности.
// Сейчас: Platform → Tenant, Organization, User.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== context: platform (packages/platform/prisma/schema.prisma) =====
enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum PlanType {
  FREE
  PRO
  BUSINESS
}

model Tenant {
  id        String       @id @db.Uuid
  name      String       @db.VarChar(255)
  slug      String       @unique @db.VarChar(64)
  plan      PlanType     @default(FREE)
  status    TenantStatus @default(ACTIVE)
  version   Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@map("tenants")
}

model Organization {
  id        String    @id @db.Uuid
  tenantId  String    @db.Uuid
  name      String    @db.VarChar(255)
  inn       String?   @db.VarChar(12)
  settings  Json?
  version   Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@map("organizations")
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

model User {
  id          String     @id @db.Uuid
  email       String     @unique @db.VarChar(255)
  name        String     @db.VarChar(255)
  avatarUrl   String?    @db.VarChar(2048)
  locale      String     @default("ru-RU") @db.VarChar(16)
  timezone    String     @default("Europe/Moscow") @db.VarChar(64)
  status      UserStatus @default(INVITED)
  lastLoginAt DateTime?
  version     Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@map("users")
}

model Credential {
  id           String   @id @db.Uuid
  userId       String   @unique @db.Uuid
  passwordHash String   @db.VarChar(255)
  version      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@map("credentials")
}

model Session {
  id               String    @id @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String    @unique @db.VarChar(64)
  expiresAt        DateTime
  revokedAt        DateTime?
  version          Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([userId])
  @@map("sessions")
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

model Membership {
  id             String           @id @db.Uuid
  tenantId       String           @db.Uuid
  userId         String           @db.Uuid
  organizationId String           @db.Uuid
  roleId         String?          @db.Uuid
  status         MembershipStatus @default(PENDING)
  invitedBy      String?          @db.Uuid
  invitedAt      DateTime?
  joinedAt       DateTime?
  leftAt         DateTime?
  isDefault      Boolean          @default(false)
  version        Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@unique([userId, organizationId])
  @@index([tenantId])
  @@index([userId])
  @@index([organizationId])
  @@map("memberships")
}

// ===== context: crm (Contact MVP) =====
enum ContactStatus {
  ACTIVE
  ARCHIVED
}

model Contact {
  id             String        @id @db.Uuid
  tenantId       String        @db.Uuid
  organizationId String        @db.Uuid
  name           String        @db.VarChar(255)
  phone          String?       @db.VarChar(50)
  email          String?       @db.VarChar(255)
  status         ContactStatus @default(ACTIVE)
  version        Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([organizationId])
  @@map("contacts")
}

model ContactNote {
  id             String   @id @db.Uuid
  tenantId       String   @db.Uuid
  organizationId String   @db.Uuid
  contactId      String   @db.Uuid
  body           String   @db.Text
  createdById    String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([contactId])
  @@index([organizationId])
  @@map("contact_notes")
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  RINGING
  COMPLETED
  MISSED
}

model Call {
  id             String        @id @db.Uuid
  tenantId       String        @db.Uuid
  organizationId String        @db.Uuid
  contactId      String        @db.Uuid
  direction      CallDirection
  phone          String        @db.VarChar(50)
  status         CallStatus    @default(RINGING)
  startedAt      DateTime      @default(now())
  endedAt        DateTime?
  durationSec    Int?
  version        Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([organizationId])
  @@index([contactId])
  @@map("calls")
}

// ===== context: crm (Request / заявка MVP) =====
enum RequestSource {
  MANUAL
  FILE
}

enum RequestStatus {
  DRAFT
  SEARCHED
}

model Request {
  id             String        @id @db.Uuid
  tenantId       String        @db.Uuid
  organizationId String        @db.Uuid
  contactId      String?       @db.Uuid
  title          String?       @db.VarChar(255)
  notes          String?       @db.VarChar(2000)
  source         RequestSource @default(MANUAL)
  status         RequestStatus @default(DRAFT)
  searchResult   Json?
  version        Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  lines          RequestLine[]

  @@index([tenantId])
  @@index([organizationId])
  @@index([contactId])
  @@map("requests")
}

model RequestLine {
  id          String  @id @db.Uuid
  requestId   String  @db.Uuid
  sortOrder   Int     @default(0)
  gost        String? @db.VarChar(64)
  steelGrade  String? @db.VarChar(64)
  productType String? @db.VarChar(128)
  dimensions  String? @db.VarChar(128)
  length      String? @db.VarChar(64)
  thickness   String? @db.VarChar(64)
  coating     String? @db.VarChar(64)
  quantity    String? @db.VarChar(32)
  unit        String? @db.VarChar(16)
  rawLine     String? @db.VarChar(500)
  request     Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("request_lines")
}
