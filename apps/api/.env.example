# apps/api — copy to .env (never commit .env)
# Local Postgres: docker compose up postgres -d
DATABASE_URL="postgresql://saas:saas@localhost:5432/saas?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
JWT_SECRET=dev-local-jwt-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
