// Platform context — Tenant (ADR-014 per-context schema).
// Собирается в apps/api/prisma/schema.prisma. Общие generator/datasource — в
// packages/database/prisma/base.prisma; здесь только модели/enum контекста.

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum PlanType {
  FREE
  PRO
  BUSINESS
}

model Tenant {
  id        String       @id @db.Uuid            // UUIDv7 (генерируется приложением)
  name      String       @db.VarChar(255)
  slug      String       @unique @db.VarChar(64)
  plan      PlanType     @default(FREE)
  status    TenantStatus @default(ACTIVE)
  version   Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@map("tenants")
}

model Organization {
  id        String    @id @db.Uuid
  tenantId  String    @db.Uuid
  name      String    @db.VarChar(255)
  inn       String?   @db.VarChar(12)
  settings  Json?
  version   Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@map("organizations")
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

model User {
  id          String     @id @db.Uuid
  email       String     @unique @db.VarChar(255)
  name        String     @db.VarChar(255)
  avatarUrl   String?    @db.VarChar(2048)
  locale      String     @default("ru-RU") @db.VarChar(16)
  timezone    String     @default("Europe/Moscow") @db.VarChar(64)
  status      UserStatus @default(INVITED)
  lastLoginAt DateTime?
  version     Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@map("users")
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

model Membership {
  id             String           @id @db.Uuid
  tenantId       String           @db.Uuid
  userId         String           @db.Uuid
  organizationId String           @db.Uuid
  roleId         String?          @db.Uuid
  status         MembershipStatus @default(PENDING)
  invitedBy      String?          @db.Uuid
  invitedAt      DateTime?
  joinedAt       DateTime?
  leftAt         DateTime?
  isDefault      Boolean          @default(false)
  version        Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@unique([userId, organizationId])
  @@index([tenantId])
  @@index([userId])
  @@index([organizationId])
  @@map("memberships")
}
