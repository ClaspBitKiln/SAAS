// CRM bounded context — Prisma schema (AI Sales OS)
// PostgreSQL, multi-tenant (tenant_id на всех таблицах).
// pg_trgm GIN-индексы добавляются миграцией вручную (см. низ файла).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum ActivityType {
  CALL
  MESSAGE
  EMAIL
  MEETING
  NOTE
  TASK
}

enum CustomFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
  MULTISELECT
}

enum EntityType {
  COMPANY
  CONTACT
  DEAL
}

model Company {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  name           String    @db.VarChar(255)
  inn            String?   @db.VarChar(12)
  kpp            String?   @db.VarChar(9)
  website        String?   @db.VarChar(255)
  industry       String?   @db.VarChar(255)
  employeesCount Int?
  address        String?
  description     String?
  ownerUserId    String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  contacts       Contact[]
  deals          Deal[]
  tags           CompanyTag[]

  @@unique([tenantId, inn])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, createdAt])
  @@index([tenantId, ownerUserId])
  @@map("companies")
}

model Contact {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  companyId   String?   @db.Uuid
  name        String    @db.VarChar(255)
  position    String?   @db.VarChar(255)
  phone       String?   @db.VarChar(50)
  email       String?   @db.VarChar(255)
  telegram    String?   @db.VarChar(255)
  maxId       String?   @db.VarChar(255)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company     Company?  @relation(fields: [companyId], references: [id])
  deals       Deal[]
  tags        ContactTag[]

  @@index([tenantId])
  @@index([tenantId, companyId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@map("contacts")
}

model Pipeline {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String   @db.VarChar(255)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages    Stage[]
  deals     Deal[]

  @@index([tenantId])
  @@map("pipelines")
}

model Stage {
  id          String  @id @default(uuid()) @db.Uuid
  pipelineId  String  @db.Uuid
  name        String  @db.VarChar(255)
  position    Int
  probability Int     @default(0)
  color       String? @db.VarChar(9)
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)

  pipeline    Pipeline @relation(fields: [pipelineId], references: [id])
  deals       Deal[]

  @@unique([pipelineId, position])
  @@index([pipelineId])
  @@map("stages")
}

model Deal {
  id                String     @id @default(uuid()) @db.Uuid
  tenantId          String     @db.Uuid
  companyId         String?    @db.Uuid
  contactId         String?    @db.Uuid
  pipelineId        String     @db.Uuid
  stageId           String     @db.Uuid
  title             String     @db.VarChar(255)
  amount            Decimal    @default(0) @db.Decimal(15, 2)
  currency          String     @default("RUB") @db.VarChar(10)
  probability       Int        @default(0)
  status            DealStatus @default(OPEN)
  expectedCloseDate DateTime?  @db.Date
  lostReason        String?
  ownerUserId       String?    @db.Uuid
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  closedAt          DateTime?

  company           Company?   @relation(fields: [companyId], references: [id])
  contact           Contact?   @relation(fields: [contactId], references: [id])
  pipeline          Pipeline   @relation(fields: [pipelineId], references: [id])
  stage             Stage      @relation(fields: [stageId], references: [id])
  products          DealProduct[]

  @@index([tenantId])
  @@index([tenantId, stageId])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, companyId])
  @@map("deals")
}

model Product {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  name        String  @db.VarChar(255)
  sku         String? @db.VarChar(100)
  price       Decimal @default(0) @db.Decimal(15, 2)
  currency    String  @default("RUB") @db.VarChar(10)
  description String?

  dealProducts DealProduct[]

  @@index([tenantId])
  @@map("products")
}

model DealProduct {
  dealId    String  @db.Uuid
  productId String  @db.Uuid
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(15, 2)

  deal      Deal    @relation(fields: [dealId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@id([dealId, productId])
  @@map("deal_products")
}

model Tag {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  name     String @db.VarChar(100)
  color    String? @db.VarChar(9)

  companies CompanyTag[]
  contacts  ContactTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

model CompanyTag {
  companyId String  @db.Uuid
  tagId     String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([companyId, tagId])
  @@map("company_tags")
}

model ContactTag {
  contactId String  @db.Uuid
  tagId     String  @db.Uuid
  contact   Contact @relation(fields: [contactId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Note {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  entityType      EntityType
  entityId        String     @db.Uuid
  body            String
  createdByUserId String?    @db.Uuid
  createdAt       DateTime   @default(now())

  @@index([tenantId, entityType, entityId])
  @@map("notes")
}

model Activity {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @db.Uuid
  type            ActivityType
  companyId       String?      @db.Uuid
  contactId       String?      @db.Uuid
  dealId          String?      @db.Uuid
  payload         Json?
  occurredAt      DateTime     @default(now())
  createdByUserId String?      @db.Uuid
  createdAt       DateTime     @default(now())

  @@index([tenantId, companyId, occurredAt])
  @@index([tenantId, dealId, occurredAt])
  @@map("activities")
}

model TimelineEvent {
  id         String     @id @default(uuid()) @db.Uuid
  tenantId   String     @db.Uuid
  entityType EntityType
  entityId   String     @db.Uuid
  kind       String     @db.VarChar(64)
  title      String     @db.VarChar(255)
  payload    Json?
  occurredAt DateTime   @default(now())

  @@index([tenantId, entityType, entityId, occurredAt])
  @@map("timeline_events")
}

model CustomFieldDef {
  id         String          @id @default(uuid()) @db.Uuid
  tenantId   String          @db.Uuid
  entityType EntityType
  key        String          @db.VarChar(64)
  label      String          @db.VarChar(255)
  type       CustomFieldType
  options    String[]
  createdAt  DateTime        @default(now())

  values     CustomFieldValue[]

  @@unique([tenantId, entityType, key])
  @@index([tenantId, entityType])
  @@map("custom_field_defs")
}

model CustomFieldValue {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @db.Uuid
  defId      String         @db.Uuid
  entityType EntityType
  entityId   String         @db.Uuid
  value      Json?

  def        CustomFieldDef @relation(fields: [defId], references: [id])

  @@unique([defId, entityId])
  @@index([tenantId, entityType, entityId])
  @@map("custom_field_values")
}

